# ── HTTP server ───────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://notify:notify@localhost:5432/notifyhub
POSTGRES_USER=notify
POSTGRES_PASSWORD=notify
POSTGRES_DB=notifyhub

# ── Redis / BullMQ ────────────────────────────────────────────────────────────
# Docker Compose overrides REDIS_HOST/PORT automatically to redis:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Authentication ────────────────────────────────────────────────────────────
# Master admin API key — seeded on every startup.
# If omitted, an auto-generated key is printed to the console on first run.
# Format: nhk_<48 hex chars>  OR any string you prefer.
MASTER_API_KEY=

# ── Swagger ───────────────────────────────────────────────────────────────────
SWAGGER_PATH=/docs
SWAGGER_JSON_PATH=/docs-json

# ── WhatsApp / Baileys ────────────────────────────────────────────────────────
WHATSAPP_AUTH_DIR=/app/data/baileys-auth
WHATSAPP_RECONNECT_BASE_DELAY_MS=5000
WHATSAPP_RECONNECT_MAX_DELAY_MS=60000

# Server-Sent Events route for WhatsApp QR updates
QR_STREAM_PATH=/events/whatsapp/qr

# ── Queue Rate Limits ─────────────────────────────────────────────────────────
WHATSAPP_RATE_LIMIT_MAX=1
WHATSAPP_RATE_LIMIT_DURATION=1000

# ── Queue Retry Policy ────────────────────────────────────────────────────────
QUEUE_DEFAULT_ATTEMPTS=3
QUEUE_DEFAULT_BACKOFF_MS=5000
QUEUE_DEFAULT_BACKOFF_TYPE=exponential
