# HTTP server
PORT=3000

# Optional Baileys auth directory (used in local/non-docker runs)
WHATSAPP_AUTH_DIR=/app/data/baileys-auth

# Reconnect backoff config for Baileys socket
WHATSAPP_RECONNECT_BASE_DELAY_MS=5000
WHATSAPP_RECONNECT_MAX_DELAY_MS=60000

# Swagger endpoints
SWAGGER_PATH=/docs
SWAGGER_JSON_PATH=/docs-json

# Server-Sent Events route for latest WhatsApp QR updates
QR_STREAM_PATH=/events/whatsapp/qr

# Redis / BullMQ Connection
REDIS_HOST=localhost
REDIS_PORT=6380

# Queue Rate Limits
WHATSAPP_RATE_LIMIT_MAX=1
WHATSAPP_RATE_LIMIT_DURATION=1000
